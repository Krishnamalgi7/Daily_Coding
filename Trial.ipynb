   "cell_type": "code",
   "source": [
    "nums = [1,1,2,3,4,4,5]\n",
    "\n",
    "n = len(nums)\n",
    "\n",
    "if n==0:\n",
    "    print(\"Empty List\")\n",
    "else:\n",
    "    i=0\n",
    "\n",
    "    for j in range(1,n):\n",
    "        if nums[i] != nums[j]:\n",
    "            i=i+1\n",
    "            nums[i] = nums[j]\n",
    "\n",
    "    print(nums[:i+1])\n"
   ],
