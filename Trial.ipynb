   "source": [
    "def check_sorted(nums):\n",
    "    n = len(nums)\n",
    "\n",
    "    for i in range(0,n-1):\n",
    "        if nums[i] > nums[i+1]:\n",
    "            return False\n",
    "\n",
    "    return True\n",
    "\n",
    "nums = [3,5,6,8,9,10,20]\n",
    "print(check_sorted(nums))"
   ],
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "True\n"
     ]
    }
   ],
