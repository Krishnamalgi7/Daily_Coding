   "cell_type": "code",
   "source": [
    "nums = [5, -2, 3, 9, 0, 6, 10, 7]\n",
    "\n",
    "n = len(nums)\n",
    "temp = nums[n-1]\n",
    "\n",
    "for i in range(n-2, -1, -1):\n",
    "    nums[i+1] = nums[i]\n",
    "\n",
    "nums[0] = temp\n",
    "\n",
    "print(nums)\n"
   ],
